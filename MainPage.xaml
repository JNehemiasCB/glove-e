<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:glove_e.ViewModels"
             x:Class="glove_e.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Glove-E">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <Label Text="{Binding Saludo}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Indicador de distancia en vivo -->
            <Border Stroke="{Binding EstadoBrush}"
                    StrokeThickness="6"
                    StrokeShape="RoundRectangle 110"
                    HeightRequest="220"
                    WidthRequest="220"
                    HorizontalOptions="Center">
                <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                    <Label Text="{Binding DistanciaTexto}"
                           FontSize="58"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label Text="cm"
                           FontSize="18"
                           TextColor="Gray"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding EstadoTexto}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{Binding EstadoColor}"
                   HorizontalOptions="Center" />

            <!-- Conexión BLE -->
            <Button Text="{Binding ConnectButtonText}"
                    Command="{Binding ToggleConnectionCommand}"
                    HorizontalOptions="Fill" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <!-- Botón de auxilio -->
            <Button Text="🚨  PEDIR AYUDA"
                    Command="{Binding SendAlertCommand}"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    FontSize="20"
                    FontAttributes="Bold"
                    HeightRequest="70"
                    CornerRadius="16"
                    HorizontalOptions="Fill" />

            <Label Text="Al presionar, se enviará un mensaje a tu contacto de emergencia."
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
